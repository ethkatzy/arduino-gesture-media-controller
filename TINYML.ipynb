    "import numpy as np\n",
    "import pandas as pd\n",
    "import tensorflow as tf\n",
    "from tensorflow import keras\n",
    "from tensorflow.keras import layers\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "import matplotlib.pyplot as plt\n",
    "import os\n",
    "import json\n",
    "\n",
    "# Optional but useful\n",
    "try:\n",
    "    import seaborn as sns\n",
    "    HAS_SNS = True\n",
    "except ImportError:\n",
    "    HAS_SNS = False\n",
    "\n",
    "SEED = 42\n",
    "np.random.seed(SEED)\n",
    "tf.random.set_seed(SEED)\n",
    "\n",

    "CSV_PATH = \"muc9/training_data(in).csv\"   
    "USE_GYRO = True                           # True = use ax,ay,az,gx,gy,gz\n",
    "TEST_SIZE = 0.2\n",
    "VAL_SIZE = 0.2                            
    "BATCH_SIZE = 16\n",
    "EPOCHS = 35\n",
    "\n",
  
    "LABEL_MAP = {\n",
    "    \"swipe_up\": \"up\",\n",
    "    \"swipe_down\": \"down\",\n",
    "    \"swipe_right\": \"right\",\n",
    "    \"swipe_left\": \"left\",\n",
    "    # if later you add idle data:\n",
    "    # \"idle\": \"idle\",\n",
    "}\n",
    "\n",
    "# If you later add idle, include it here too.\n",
    "CLASS_NAMES = [\"up\", \"down\", \"right\", \"left\"]\n",
    "\n",
  
    "df = pd.read_csv(CSV_PATH)\n",
    "\n",
    "required_cols = {\"recording_id\", \"gesture\", \"ax\", \"ay\", \"az\", \"gx\", \"gy\", \"gz\"}\n",
    "missing = required_cols - set(df.columns)\n",
    "if missing:\n",
    "    raise ValueError(f\"Missing required columns: {missing}\")\n",
    "\n",
    "print(\"Loaded shape:\", df.shape)\n",
    "print(df.head())\n",
    "\n",
    "# Keep only gestures we know how to map\n",
    "df = df[df[\"gesture\"].isin(LABEL_MAP.keys())].copy()\n",
    "df[\"label_name\"] = df[\"gesture\"].map(LABEL_MAP)\n",
    "\n",
    "print(\"\\nGesture counts (rows):\")\n",
    "print(df[\"label_name\"].value_counts())\n",
    "\n",
  
    "feature_cols = [\"ax\", \"ay\", \"az\", \"gx\", \"gy\", \"gz\"] if USE_GYRO else [\"ax\", \"ay\", \"az\"]\n",
    "\n",
    "X_list = []\n",
    "y_list = []\n",
    "record_keys = []\n",
    "\n",
    "grouped = df.groupby([\"gesture\", \"recording_id\"], sort=True)\n",
    "\n",
    "lengths = []\n",
    "for (gesture_raw, rec_id), group in grouped:\n",
    "    # preserve row order as found in file\n",
    "    group = group.reset_index(drop=True)\n",
    "\n",
    "    x = group[feature_cols].to_numpy(dtype=np.float32)\n",
    "    y_name = LABEL_MAP[gesture_raw]\n",
    "\n",
    "    X_list.append(x)\n",
    "    y_list.append(y_name)\n",
    "    record_keys.append((gesture_raw, rec_id))\n",
    "    lengths.append(len(x))\n",
    "\n",
    "lengths = np.array(lengths)\n",
    "print(\"\\nNum recordings:\", len(X_list))\n",
    "print(\"Recording length stats:\", {\n",
    "    \"min\": int(lengths.min()),\n",
    "    \"max\": int(lengths.max()),\n",
    "    \"unique\": np.unique(lengths).tolist()\n",
    "})\n",
    "\n",
    "# Require fixed length for a simple tinyML model\n",
    "if len(np.unique(lengths)) != 1:\n",
    "    raise ValueError(\n",
    "        f\"Recordings do not all have the same length. Found lengths: {np.unique(lengths)}\"\n",
    "    )\n",
    "\n",
    "TIMESTEPS = lengths[0]\n",
    "NUM_CHANNELS = len(feature_cols)\n",
    "\n",
    "X = np.stack(X_list)  # shape: (num_recordings, timesteps, channels)\n",
    "y_names = np.array(y_list)\n",
    "\n",
    "print(\"X shape:\", X.shape)\n",
    "print(\"y shape:\", y_names.shape)\n",
    "\n",

    "class_to_idx = {name: i for i, name in enumerate(CLASS_NAMES)}\n",
    "idx_to_class = {i: name for name, i in class_to_idx.items()}\n",
    "\n",
    "if not set(y_names).issubset(set(CLASS_NAMES)):\n",
    "    bad = set(y_names) - set(CLASS_NAMES)\n",
    "    raise ValueError(f\"Unexpected labels after mapping: {bad}\")\n",
    "\n",
    "y = np.array([class_to_idx[name] for name in y_names], dtype=np.int32)\n",
    "\n",
    "print(\"\\nClass mapping:\", class_to_idx)\n",
    "print(\"Class counts (recordings):\")\n",
    "for name in CLASS_NAMES:\n",
    "    print(f\"  {name}: {(y_names == name).sum()}\")\n",
    "\n",

    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y,\n",
    "    test_size=TEST_SIZE,\n",
    "    random_state=SEED,\n",
    "    stratify=y\n",
    ")\n",
    "\n",
    "X_train, X_val, y_train, y_val = train_test_split(\n",
    "    X_train, y_train,\n",
    "    test_size=VAL_SIZE,\n",
    "    random_state=SEED,\n",
    "    stratify=y_train\n",
    ")\n",
    "\n",
    "print(\"\\nTrain/Val/Test shapes:\")\n",
    "print(\"X_train:\", X_train.shape, \"y_train:\", y_train.shape)\n",
    "print(\"X_val:  \", X_val.shape,   \"y_val:  \", y_val.shape)\n",
    "print(\"X_test: \", X_test.shape,  \"y_test: \", y_test.shape)\n",
    "\n",

    "channel_mean = X_train.mean(axis=(0, 1), keepdims=True)\n",
    "channel_std = X_train.std(axis=(0, 1), keepdims=True) + 1e-6\n",
    "\n",
    "X_train = (X_train - channel_mean) / channel_std\n",
    "X_val   = (X_val   - channel_mean) / channel_std\n",
    "X_test  = (X_test  - channel_mean) / channel_std\n",
    "\n",
    "print(\"\\nNormalization stats:\")\n",
    "print(\"mean shape:\", channel_mean.shape)\n",
    "print(\"std shape: \", channel_std.shape)\n",
    "\n",

    "num_classes = len(CLASS_NAMES)\n",
    "\n",
    "model = keras.Sequential([\n",
    "    layers.Input(shape=(TIMESTEPS, NUM_CHANNELS)),\n",
    "\n",
    "    layers.Conv1D(16, kernel_size=5, padding=\"same\", activation=\"relu\"),\n",
    "    layers.BatchNormalization(),\n",
    "    layers.MaxPooling1D(pool_size=2),\n",
    "\n",
    "    layers.Conv1D(24, kernel_size=5, padding=\"same\", activation=\"relu\"),\n",
    "    layers.BatchNormalization(),\n",
    "    layers.MaxPooling1D(pool_size=2),\n",
    "\n",
    "    layers.Conv1D(32, kernel_size=3, padding=\"same\", activation=\"relu\"),\n",
    "    layers.GlobalAveragePooling1D(),\n",
    "\n",
    "    layers.Dense(24, activation=\"relu\"),\n",
    "    layers.Dropout(0.2),\n",
    "    layers.Dense(num_classes, activation=\"softmax\")\n",
    "])\n",
    "\n",
    "model.compile(\n",
    "    optimizer=keras.optimizers.Adam(learning_rate=1e-3),\n",
    "    loss=\"sparse_categorical_crossentropy\",\n",
    "    metrics=[\"accuracy\"]\n",
    ")\n",
    "\n",
    "model.summary()\n",
    "\n",

    "callbacks = [\n",
    "    keras.callbacks.EarlyStopping(\n",
    "        monitor=\"val_accuracy\",\n",
    "        patience=8,\n",
    "        restore_best_weights=True\n",
    "    )\n",
    "]\n",
    "\n",
    "history = model.fit(\n",
    "    X_train, y_train,\n",
    "    validation_data=(X_val, y_val),\n",
    "    epochs=EPOCHS,\n",
    "    batch_size=BATCH_SIZE,\n",
    "    callbacks=callbacks,\n",
    "    verbose=1\n",
    ")\n",
    "\n",

    "test_loss, test_acc = model.evaluate(X_test, y_test, verbose=0)\n",
    "print(f\"\\nTest loss: {test_loss:.4f}\")\n",
    "print(f\"Test accuracy: {test_acc:.4f}\")\n",
    "\n",
    "y_prob = model.predict(X_test)\n",
    "y_pred = np.argmax(y_prob, axis=1)\n",
    "\n",
    "print(\"\\nClassification report:\")\n",
    "print(classification_report(\n",
    "    y_test,\n",
    "    y_pred,\n",
    "    target_names=CLASS_NAMES,\n",
    "    digits=4\n",
    "))\n",
    "\n",
    "cm = confusion_matrix(y_test, y_pred)\n",
    "\n",
    "plt.figure(figsize=(6, 5))\n",
    "if HAS_SNS:\n",
    "    sns.heatmap(cm, annot=True, fmt=\"d\", xticklabels=CLASS_NAMES, yticklabels=CLASS_NAMES)\n",
    "else:\n",
    "    plt.imshow(cm)\n",
    "    plt.xticks(range(len(CLASS_NAMES)), CLASS_NAMES, rotation=45)\n",
    "    plt.yticks(range(len(CLASS_NAMES)), CLASS_NAMES)\n",
    "    for i in range(cm.shape[0]):\n",
    "        for j in range(cm.shape[1]):\n",
    "            plt.text(j, i, str(cm[i, j]), ha=\"center\", va=\"center\")\n",
    "plt.xlabel(\"Predicted\")\n",
    "plt.ylabel(\"True\")\n",
    "plt.title(\"Confusion Matrix\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
   
    "model.save(\"gesture_model.keras\")\n",
    "\n",
    "# Save normalization stats for deployment\n",
    "np.save(\"channel_mean.npy\", channel_mean)\n",
    "np.save(\"channel_std.npy\", channel_std)\n",
    "\n",
    "print(\"\\nSaved:\")\n",
    "print(\"- gesture_model.keras\")\n",
    "print(\"- channel_mean.npy\")\n",
    "print(\"- channel_std.npy\")\n",
    "\n",

    "SAVE_DIR = \".\"\n",
    "WEIGHTS_PATH = os.path.join(SAVE_DIR, \"gesture_model.weights.h5\")\n",
    "MEAN_PATH = os.path.join(SAVE_DIR, \"channel_mean.npy\")\n",
    "STD_PATH = os.path.join(SAVE_DIR, \"channel_std.npy\")\n",
    "CONFIG_PATH = os.path.join(SAVE_DIR, \"gesture_model_config.json\")\n",
    "\n",
    "# 1) Save only the model weights\n",
    "model.save_weights(WEIGHTS_PATH)\n",
    "\n",
    "# 2) Save normalization stats\n",
    "np.save(MEAN_PATH, channel_mean)\n",
    "np.save(STD_PATH, channel_std)\n",
    "\n",
    "# 3) Save config / label info\n",
    "config = {\n",
    "    \"timesteps\": int(TIMESTEPS),\n",
    "    \"num_channels\": int(NUM_CHANNELS),\n",
    "    \"class_names\": CLASS_NAMES,\n",
    "    \"use_gyro\": USE_GYRO\n",
    "}\n",
    "\n",
    "with open(CONFIG_PATH, \"w\") as f:\n",
    "    json.dump(config, f, indent=2)\n",
    "\n",
    "print(\"\\nSaved weights + metadata:\")\n",
    "print(\"-\", WEIGHTS_PATH)\n",
    "print(\"-\", MEAN_PATH)\n",
    "print(\"-\", STD_PATH)\n",
    "print(\"-\", CONFIG_PATH)\n",
    "\n",
 
    "def representative_dataset():\n",
    "    for i in range(min(len(X_train), 100)):\n",
    "        sample = X_train[i:i+1].astype(np.float32)\n",
    "        yield [sample]\n",
    "\n",
    "converter = tf.lite.TFLiteConverter.from_keras_model(model)\n",
    "converter.optimizations = [tf.lite.Optimize.DEFAULT]\n",
    "converter.representative_dataset = representative_dataset\n",
    "converter.target_spec.supported_ops = [tf.lite.OpsSet.TFLITE_BUILTINS_INT8]\n",
    "converter.inference_input_type = tf.int8\n",
    "converter.inference_output_type = tf.int8\n",
    "\n",
    "tflite_model = converter.convert()\n",
    "\n",
    "with open(\"gesture_model_int8.tflite\", \"wb\") as f:\n",
    "    f.write(tflite_model)\n",
    "\n",
    "print(\"\\nSaved INT8 TFLite model: gesture_model_int8.tflite\")\n",
    "print(\"Model size (bytes):\", len(tflite_model))\n",
    "\n",
  
    "interpreter = tf.lite.Interpreter(model_path=\"gesture_model_int8.tflite\")\n",
    "interpreter.allocate_tensors()\n",
    "\n",
    "input_details = interpreter.get_input_details()[0]\n",
    "output_details = interpreter.get_output_details()[0]\n",
    "\n",
    "print(\"\\nTFLite input details:\", input_details)\n",
    "print(\"TFLite output details:\", output_details)\n",
    "\n",
    "def run_tflite_inference(sample_float32):\n",
    "    \"\"\"\n",
    "    sample_float32 shape: (1, TIMESTEPS, NUM_CHANNELS), already normalized\n",
    "    \"\"\"\n",
    "    in_scale, in_zero = input_details[\"quantization\"]\n",
    "    out_scale, out_zero = output_details[\"quantization\"]\n",
    "\n",
    "    sample_int8 = np.round(sample_float32 / in_scale + in_zero).astype(np.int8)\n",
    "    interpreter.set_tensor(input_details[\"index\"], sample_int8)\n",
    "    interpreter.invoke()\n",
    "    output_int8 = interpreter.get_tensor(output_details[\"index\"])\n",
    "\n",
    "    # dequantize\n",
    "    output_float = (output_int8.astype(np.float32) - out_zero) * out_scale\n",
    "    pred_idx = int(np.argmax(output_float[0]))\n",
    "    return pred_idx, output_float[0]\n",
    "\n",
    "sample = X_test[0:1].astype(np.float32)\n",
    "pred_idx, scores = run_tflite_inference(sample)\n",
    "print(\"\\nExample TFLite prediction:\")\n",
    "print(\"True:\", idx_to_class[int(y_test[0])])\n",
    "print(\"Pred:\", idx_to_class[pred_idx])\n",
    "print(\"Scores:\", scores)\n",
    "\n",

    "def convert_to_c_array(bytes_data, var_name=\"gesture_model\"):\n",
    "    hex_array = \", \".join(f\"0x{b:02x}\" for b in bytes_data)\n",
    "    return f\"\"\"\n",
    "const unsigned char {var_name}[] = {{\n",
    "{hex_array}\n",
    "}};\n",
    "const unsigned int {var_name}_len = {len(bytes_data)};\n",
    "\"\"\".strip()\n",
    "\n",
    "c_text = convert_to_c_array(tflite_model, var_name=\"gesture_model\")\n",
    "with open(\"gesture_model_int8.cc\", \"w\") as f:\n",
    "    f.write(c_text)\n",
    "\n",
    "print(\"\\nSaved C array: gesture_model_int8.cc\")"
   ]
  },
